# Supabase (wajib untuk backend / Render)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# DeepSeek AI (rangkuman feedback dashboard)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Backend — izinkan frontend Netlify (pisahkan dengan koma jika banyak)
CORS_ORIGIN=https://your-app.netlify.app

# Cloudflare Turnstile CAPTCHA (opsional — jika kosong, CAPTCHA dinonaktifkan)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Frontend — URL backend Render (untuk build Netlify)
VITE_API_URL=https://your-api.onrender.com

# Frontend — URL publik situs (untuk link formulir di dashboard)
VITE_PUBLIC_SITE_URL=https://your-app.netlify.app

# Frontend — Cloudflare Turnstile site key (pasangan TURNSTILE_SECRET_KEY)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Opsional (local)
PORT=3001
